rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow authenticated users to read/write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow authenticated users to read/write their own brand data
    match /v8userbrands/{brandId} {
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.userId;
      allow read, delete: if request.auth != null &&
        request.auth.uid == resource.data.userId;
      allow update: if request.auth != null &&
        request.auth.uid == resource.data.userId &&
        request.resource.data.userId == resource.data.userId;
    }

    // Allow authenticated users to read/write their own query documents
    match /v8userqueries/{queryId} {
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.userId;
      allow read, delete: if request.auth != null &&
        request.auth.uid == resource.data.userId;
      allow update: if request.auth != null &&
        request.auth.uid == resource.data.userId &&
        request.resource.data.userId == resource.data.userId;
    }
    
    // Allow authenticated users to read/write their own detailed query results
    match /v8detailed_query_results/{resultId} {
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.userId;
      allow read, delete: if request.auth != null &&
        request.auth.uid == resource.data.userId;
      allow update: if request.auth != null &&
        request.auth.uid == resource.data.userId &&
        request.resource.data.userId == resource.data.userId;
    }
    
    // Allow authenticated users to read/write their own brand analytics
    match /v8_user_brand_analytics/{analyticsId} {
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.userId;
      allow read, delete: if request.auth != null &&
        request.auth.uid == resource.data.userId;
      allow update: if request.auth != null &&
        request.auth.uid == resource.data.userId &&
        request.resource.data.userId == resource.data.userId;
    }

    // Allow authenticated users to read/write their own competitor analytics
    match /v8competitoranalytics/{analyticsId} {
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.userId;
      allow read, delete: if request.auth != null &&
        request.auth.uid == resource.data.userId;
      allow update: if request.auth != null &&
        request.auth.uid == resource.data.userId &&
        request.resource.data.userId == resource.data.userId;
    }
    
    // Allow authenticated users to read/write their own lifetime analytics
    match /v8_lifetime_brand_analytics/{analyticsId} {
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.userId;
      allow read, delete: if request.auth != null &&
        request.auth.uid == resource.data.userId;
      allow update: if request.auth != null &&
        request.auth.uid == resource.data.userId &&
        request.resource.data.userId == resource.data.userId;
    }

    // Dashboard metric document keyed by user ID.
    match /user_metrics/{userId} {
      allow read, write: if request.auth != null &&
        request.auth.uid == userId;
    }

    // Dashboard collections with userId stored on each document.
    match /user_recommendations/{documentId} {
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.userId;
      allow read, delete: if request.auth != null &&
        request.auth.uid == resource.data.userId;
      allow update: if request.auth != null &&
        request.auth.uid == resource.data.userId &&
        request.resource.data.userId == resource.data.userId;
    }

    match /user_top_domains/{documentId} {
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.userId;
      allow read, delete: if request.auth != null &&
        request.auth.uid == resource.data.userId;
      allow update: if request.auth != null &&
        request.auth.uid == resource.data.userId &&
        request.resource.data.userId == resource.data.userId;
    }

    match /user_trends/{documentId} {
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.userId;
      allow read, delete: if request.auth != null &&
        request.auth.uid == resource.data.userId;
      allow update: if request.auth != null &&
        request.auth.uid == resource.data.userId &&
        request.resource.data.userId == resource.data.userId;
    }

    match /user_brand_prompts/{documentId} {
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.userId;
      allow read, delete: if request.auth != null &&
        request.auth.uid == resource.data.userId;
      allow update: if request.auth != null &&
        request.auth.uid == resource.data.userId &&
        request.resource.data.userId == resource.data.userId;
    }

    // Leaderboard is shared read-only data for signed-in users.
    match /brand_leaderboard/{documentId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        request.auth.token.email in [
          'admin@example.com',
          'developer@example.com',
          'team@getaimonitor.com',
          'write2avinash007@gmail.com'
        ];
    }
    
    // Deny all other client-side access by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
} 
